# ---------------------------------------------------------------------------
# AgentOS backend environment — copy to .env and fill in.
# ---------------------------------------------------------------------------

# --- LLM (Cognee uses these for entity extraction + graph completion) ------
# Cognee reads LLM_API_KEY first, then falls back to OPENAI_API_KEY.
LLM_API_KEY=sk-...
OPENAI_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- Embeddings ------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Cognee storage --------------------------------------------------------
# Leave unset to use the embedded default stack (SQLite + LanceDB + Kuzu).
# One change here swaps to Neo4j / pgvector / Postgres for production.
# COGNEE_GRAPH_DATABASE_PROVIDER=kuzu
# Where Cognee keeps its embedded databases (defaults to ~/.cognee).
# COGNEE_SYSTEM_ROOT_DIRECTORY=./.cognee_data

# --- Tools (Researcher, used Day 2+) ---------------------------------------
TAVILY_API_KEY=

# --- AgentOS app DB --------------------------------------------------------
# Thin coordination tables only (domains/sessions/sources/confidence).
APP_DATABASE_URL=sqlite+aiosqlite:///./agentos.db

# --- Auth (demo) -----------------------------------------------------------
DEMO_USER=demo
DEMO_TOKEN=dev-token
